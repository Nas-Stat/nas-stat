# =============================================================================
# Environment Strategy
# =============================================================================
# .env.development  — Local Supabase keys (committed, safe defaults)
# .env.local         — Your overrides (gitignored, e.g. production keys)
# .env               — Also gitignored, alternative to .env.local
#
# Next.js priority: .env.local > .env.development > .env
# For local dev with `supabase start`, .env.development works out of the box.
# To use production Supabase, create .env.local with your real keys below.
# =============================================================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# MapTiler Configuration
# .env.development already contains a working free-tier key for local dev.
# For production or your own account: https://cloud.maptiler.com/account/keys/
# Free tier: 100k tile requests/month
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key-here

# Email Notifications (Resend)
# Get your API key at https://resend.com
RESEND_API_KEY=your-resend-api-key-here
EMAIL_FROM=Náš stát <noreply@nasstat.cz>

# Public app URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
